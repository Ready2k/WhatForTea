# AIMock Testing Environment Variables
# Point Bedrock to the local AIMock server

AWS_ACCESS_KEY_ID=mock_key
AWS_SECRET_ACCESS_KEY=mock_secret
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=http://host.docker.internal:5001

# Use existing model IDs
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6
BEDROCK_TEXT_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0

# Ensure we use a test database if possible
POSTGRES_DB=whatsfortea_test
LOG_LEVEL=DEBUG
