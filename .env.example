# Copy this file to .env and fill in all values before running docker-compose.
# Never commit .env to version control.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=whatsfortea
POSTGRES_USER=whatsfortea
POSTGRES_PASSWORD=change_me_strong_password

# ── Application ───────────────────────────────────────────────────────────────
# JWT signing secret — generate with: openssl rand -hex 32
JWT_SECRET=change_me_generate_with_openssl_rand_hex_32

# Household login credentials
HOUSEHOLD_USERNAME=household
# Generate hash with: python -c "from argon2 import PasswordHasher; print(PasswordHasher().hash('yourpassword'))"
HOUSEHOLD_PASSWORD_HASH=

# Set to true in production (requires HTTPS — handled by Caddy)
COOKIE_SECURE=false

# ── AWS Bedrock ───────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6              # vision tasks (recipe scan, auto-crop)
BEDROCK_TEXT_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0  # text/chat tasks (TeaBot, normaliser, nutrition)

# ── Ports (override if defaults clash with existing services) ─────────────────
API_PORT=8000
FRONTEND_PORT=3000

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Langfuse (LLM observability) ──────────────────────────────────────────────
# Get keys from https://cloud.langfuse.com — leave blank to disable tracing
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Google OAuth SSO ─────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/ → APIs & Services → Credentials
# Authorised redirect URI: https://yourdomain.com/api/auth/google/callback
# Leave blank to disable Google SSO (password login still works).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Email / SMTP (password reset) ────────────────────────────────────────────
# Leave SMTP_HOST blank to disable email (password reset unavailable)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@yourdomain.com
# Used in reset-password link sent by email
APP_URL=http://localhost:3000

# ── Web Push (VAPID) ─────────────────────────────────────────────────────────
# Leave blank to disable push notifications.
# Generate keys (run once inside the container):
#   docker compose exec api poetry run python -c "
#   from cryptography.hazmat.primitives.asymmetric import ec
#   from cryptography.hazmat.primitives import serialization
#   import base64, json
#   k = ec.generate_private_key(ec.SECP256R1())
#   priv = base64.urlsafe_b64encode(k.private_bytes(serialization.Encoding.DER, serialization.PrivateFormat.PKCS8, serialization.NoEncryption())).decode()
#   pub = base64.urlsafe_b64encode(k.public_key().public_bytes(serialization.Encoding.X962, serialization.PublicFormat.UncompressedPoint)).rstrip(b'=').decode()
#   print(json.dumps({'VAPID_PRIVATE_KEY':priv,'VAPID_PUBLIC_KEY':pub}))"
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIMS_EMAIL=admin@whatsfortea.local

# ── Release ───────────────────────────────────────────────────────────────────
RELEASE_ID=v1.0.2

# --- Google SSO details --- 
GOOGLE_CLIENT_ID=<your-client-id>.apps.googleusercontent.com                                                         
GOOGLE_CLIENT_SECRET=<your-client-secret>                                                                            
APP_URL=https://whatsfortea.zapto.org                                                                                
COOKIE_SECURE=true 